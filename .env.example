# ── Techychat Environment Variables ────────────────────────
# Copy this file to .env and fill in your actual values.
# Then paste them directly into js/app.js lines 3-4,
# OR inject via your hosting platform's env variables.
# ────────────────────────────────────────────────────────────

# Supabase Project URL (Dashboard → Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Anon / Public Key (Dashboard → Settings → API → anon public)
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
